@article{quddusHighAccuracyFuzzy2006,
  title = {A {{High Accuracy Fuzzy Logic Based Map Matching Algorithm}} for {{Road Transport}}},
  author = {Quddus, Mohammed A. and Noland, Robert B. and Ochieng, Washington Y.},
  year = 2006,
  month = sep,
  journal = {Journal of Intelligent Transportation Systems},
  volume = {10},
