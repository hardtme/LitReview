@article{quddusCurrentMapmatchingAlgorithms2007,
  title = {Current Map-Matching Algorithms for Transport Applications: {{State-of-the}} Art and Future Research Directions},
  shorttitle = {Current Map-Matching Algorithms for Transport Applications},
  author = {Quddus, Mohammed A. and Ochieng, Washington Y. and Noland, Robert B.},
